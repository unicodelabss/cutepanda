<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Surprise for You ✨</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Poppins', sans-serif; background-color: #fce4ec; overflow: hidden; }
        
        /* Intro Screen Container */
        #intro-screen {
            position: fixed;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            transition: opacity 1s ease-out, visibility 1s;
        }

        /* Panda Styling */
        #panda-svg {
            width: 280px;
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        #panda-svg:hover { transform: scale(1.05); }

        /* Clapping Animation */
        .clapping #arm-left {
            animation: clap-left 0.3s infinite alternate ease-in-out;
            transform-origin: 100px 150px;
        }
        .clapping #arm-right {
            animation: clap-right 0.3s infinite alternate ease-in-out;
            transform-origin: 200px 150px;
        }
        
        @keyframes clap-left {
            from { transform: rotate(0deg); }
            to { transform: rotate(30deg); }
        }
        @keyframes clap-right {
            from { transform: rotate(0deg); }
            to { transform: rotate(-30deg); }
        }

        /* Smile Animation */
        #mouth { transition: d 0.3s ease; }
        .smiling #mouth {
            /* JS handles the path change for the smile */
        }

        /* Heart Particles */
        .heart {
            position: absolute;
            color: #ff4081;
            font-size: 20px;
            pointer-events: none;
            animation: fly-up 1s ease-out forwards;
        }
        @keyframes fly-up {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-100px) scale(1.5); opacity: 0; }
        }

        /* Hidden Class for Second Page */
        .hidden-content { opacity: 0; visibility: hidden; pointer-events: none; }
    </style>
</head>
<body>

    <!-- FIRST PAGE: PANDA INTRO -->
    <div id="intro-screen">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-bold text-pink-600 mb-2">Hello! Ek surprise hai...</h1>
            <p class="text-gray-500 italic">Panda pe click karke toh dekho!</p>
        </div>

        <!-- SVG PANDA -->
        <div class="relative" id="panda-trigger">
            <svg id="panda-svg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
                <!-- Ears -->
                <circle cx="80" cy="80" r="30" fill="#333" />
                <circle cx="220" cy="80" r="30" fill="#333" />
                <!-- Body -->
                <ellipse cx="150" cy="200" rx="90" ry="80" fill="white" stroke="#333" stroke-width="4"/>
                <!-- Head -->
                <circle cx="150" cy="130" r="80" fill="white" stroke="#333" stroke-width="4"/>
                <!-- Eyes Background -->
                <ellipse cx="120" cy="120" rx="15" ry="20" fill="#333" />
                <ellipse cx="180" cy="120" rx="15" ry="20" fill="#333" />
                <!-- Eye Pupils -->
                <circle cx="120" cy="115" r="5" fill="white" />
                <circle cx="180" cy="115" r="5" fill="white" />
                <!-- Nose -->
                <ellipse cx="150" cy="150" rx="8" ry="5" fill="#333" />
                <!-- Mouth (Initial state: small curve) -->
                <path id="mouth" d="M 140 165 Q 150 175 160 165" fill="none" stroke="#333" stroke-width="3" stroke-linecap="round" />
                <!-- Arms -->
                <path id="arm-left" d="M 70 180 Q 30 200 60 250" fill="none" stroke="#333" stroke-width="15" stroke-linecap="round" />
                <path id="arm-right" d="M 230 180 Q 270 200 240 250" fill="none" stroke="#333" stroke-width="15" stroke-linecap="round" />
            </svg>
        </div>
    </div>

    <!-- SECOND PAGE (Main Content Placeholder) -->
    <div id="main-content" class="min-h-screen flex items-center justify-center hidden-content transition-all duration-1000 bg-white">
        <div class="text-center">
            <h1 class="text-5xl font-['Dancing_Script'] text-pink-500 mb-6">Happy Birthday / Friendship Day!</h1>
            <p class="text-gray-600 text-xl">Yeh rahi tumhari poori website...</p>
            <div class="mt-8 text-6xl">🎂🎈✨</div>
        </div>
    </div>

    <script>
        const panda = document.getElementById('panda-svg');
        const introScreen = document.getElementById('intro-screen');
        const mainContent = document.getElementById('main-content');
        const mouth = document.getElementById('mouth');

        panda.addEventListener('click', () => {
            // 1. Add Animation Classes
            document.body.classList.add('clapping');
            
            // 2. Change Mouth to a Big Smile (SVG path update)
            mouth.setAttribute('d', 'M 130 165 Q 150 195 170 165');

            // 3. Create Heart Particles
            for(let i=0; i<10; i++) {
                createHeart();
            }

            // 4. Wait for 2 seconds then transition
            setTimeout(() => {
                // Fade out intro
                introScreen.style.opacity = '0';
                introScreen.style.visibility = 'hidden';

                // Show main content
                mainContent.classList.remove('hidden-content');
                mainContent.style.opacity = '1';
                mainContent.style.visibility = 'visible';
                
                // Allow scrolling after intro is gone
                document.body.style.overflow = 'auto';
            }, 2000);
        });

        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('heart');
            heart.innerHTML = '❤️';
            heart.style.left = (Math.random() * 100 + (window.innerWidth / 2 - 50)) + 'px';
            heart.style.top = (window.innerHeight / 2) + 'px';
            document.body.appendChild(heart);

            setTimeout(() => {
                heart.remove();
            }, 1000);
        }
    </script>
</body>
</html>
